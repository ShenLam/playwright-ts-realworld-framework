{
  "name": "playwright-ts-realworld-framework",
  "version": "1.0.0",
  "description": "Playwright + TypeScript automation framework for RealWorld API and E2E testing.",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api-tests",
    "test:e2e": "playwright test --project=e2e-tests",
    "test:headed": "playwright test --headed",
    "test:list": "playwright test --list",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShenLam/playwright-ts-realworld-framework.git"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "api-testing",
    "e2e-testing",
    "realworld"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ShenLam/playwright-ts-realworld-framework/issues"
  },
  "homepage": "https://github.com/ShenLam/playwright-ts-realworld-framework#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  }
}
