{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results"]
}
